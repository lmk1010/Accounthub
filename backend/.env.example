# ============================================
# AccountHub environment example
# Copy to backend/.env.development or export in production.
# Never commit real secrets.
# ============================================

# --- Database (MySQL) ---
USE_DATABASE=true
DB_HOST=localhost
DB_PORT=3306
DB_USER=accounthub
DB_PASSWORD=change-me
# Prefer a dedicated database name for new installs.
# Existing deployments may still use a legacy name via env override.
DB_DATABASE=accounthub
DB_CONNECTION_LIMIT=20
DB_QUEUE_LIMIT=200

# --- Redis (optional; falls back to in-memory where safe) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=accounthub:

# --- HTTP ---
HOST=0.0.0.0
SERVER_PORT=3000
REQUIRED_API_KEY=change-me-admin-or-gateway-key
OAUTH_CALLBACK_HOST=localhost
OAUTH_CALLBACK_SCHEME=http

# --- Proxy (optional) ---
# PROXY_URL=http://127.0.0.1:7890
# PROXY_ENABLED_PROVIDERS=

# --- Workers / process ---
# WORKERS=2
NODE_ENV=development

# --- Optional: Google OAuth public clients for Gemini / Antigravity ---
# Use the OAuth client credentials from your own Google Cloud project,
# or from the official Gemini CLI / Antigravity desktop app configuration.
# Do not commit real secrets.
# GEMINI_OAUTH_CLIENT_ID=
# GEMINI_OAUTH_CLIENT_SECRET=
# ANTIGRAVITY_OAUTH_CLIENT_ID=
# ANTIGRAVITY_OAUTH_CLIENT_SECRET=
