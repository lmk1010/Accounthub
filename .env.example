# AccountHub Docker Compose / installer environment template
# Copy to .env and edit. Never commit real secrets.
#
# Research / self-host lab use only — see NOTICE.md and docs/public/RESEARCH_USE.md

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change-me-root
DB_DATABASE=accounthub
DB_USER=accounthub
DB_PASSWORD=change-me
MYSQL_PORT=3306

# --- Redis ---
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=accounthub:

# --- AccountHub backend ---
REQUIRED_API_KEY=change-me-admin-or-gateway-key
HOST=0.0.0.0
SERVER_PORT=3000
OAUTH_CALLBACK_HOST=localhost
OAUTH_CALLBACK_SCHEME=http
BACKEND_PORT=13000
FRONTEND_PORT=13001

# Optional Google OAuth public clients (your own project / authorized client only)
# GEMINI_OAUTH_CLIENT_ID=
# GEMINI_OAUTH_CLIENT_SECRET=
# ANTIGRAVITY_OAUTH_CLIENT_ID=
# ANTIGRAVITY_OAUTH_CLIENT_SECRET=
